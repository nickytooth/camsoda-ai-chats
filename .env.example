# Telegram (userbot — get from https://my.telegram.org)
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+1234567890

# Anthropic (Claude) — SFW conversations
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-6

# xAI (Grok) — NSFW conversations
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-4.20-0309-non-reasoning

# Google (Gemini) — content classification + summarization
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-3-flash-preview

# OpenAI — embeddings only
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Persona
PERSONA_FILE=personas/aishha.yaml

# Content
CONTENT_CONFIG=content_config.yaml

# Database
DATABASE_PATH=data/bot.db

# Payment bot (create via @BotFather — invisible, handles Star invoices only)
PAYMENT_BOT_TOKEN=your_bot_token_here

# Humanize
MIN_RESPONSE_DELAY=60
MAX_RESPONSE_DELAY=180
