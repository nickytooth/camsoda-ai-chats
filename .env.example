# Anthropic (Claude) — SFW conversations
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# xAI (Grok) — NSFW conversations + Story mode + Vision
XAI_API_KEY=your_xai_api_key_here
XAI_MODEL=grok-3

# Google (Gemini) — classification + summarization
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_MODEL=gemini-2.0-flash

# OpenAI — embeddings only
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Persona
PERSONA_FILE=personas/victoria.yaml
NSFW_PERSONA_FILE=personas/victoria_nsfw.yaml
STORY_FILE=stories/victoria_story.yaml

# Content
CONTENT_DIR=content

# Database
DATABASE_PATH=data/bot.db

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Response delays (seconds)
MIN_RESPONSE_DELAY=3
MAX_RESPONSE_DELAY=10

# Default user ID (single-user demo)
DEFAULT_USER_ID=1
